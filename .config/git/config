[user]
	name = Szymon Wieczorek
    email = shateq21@gmail.com
[alias]
    a = add
    br = branch
    cl = clone
    co = checkout
    cm = commit -m
    df = diff
    l = log --pretty=oneline -n 20 --graph --abbrev-commit  
    s = status -s
    sm = submodule
    st = status
    sw = switch
    origin = remote get-url origin
    pr = pull --rebase
[core]
    compression = 7
    fsync = none
    whitespace = error
	autocrlf = false
[apply]
	whitespace = fix
[color]
    ui = auto
[init]
    defaultBranch = main

[ghq]
    root = ~/Projects/ghq

[url "git@github.com:"]
    insteadOf = "gh:"
[url "git@codeberg.org:"]
    insteadOf = "cb:"
[url "git@gitlab.com:"]
    insteadOf = "gl:"
